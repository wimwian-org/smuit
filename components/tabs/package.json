{
    "name": "@smuit/tabs",
    "version": "0.0.0",
    "description": "Material Design 3–style tabs for Svelte 5 — bold and subtle variants, sm/md sizes, an animated sliding indicator, leading icons, and automatic/manual activation, backed by bits-ui on smuit design tokens.",
    "type": "module",
    "files": [
        "dist",
        "!dist/**/*.test.*",
        "!dist/**/*.spec.*"
    ],
    "svelte": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "svelte": "./dist/index.js",
            "default": "./dist/index.js"
        },
        "./package.json": "./package.json"
    },
    "scripts": {
        "package": "svelte-package -i src -o dist -t",
        "build": "svelte-package -i src -o dist -t",
        "prepublishOnly": "svelte-package -i src -o dist -t"
    },
    "sideEffects": [
        "**/*.css"
    ],
    "keywords": [
        "svelte",
        "svelte5",
        "tabs",
        "tablist",
        "bits-ui",
        "material",
        "material-design",
        "m3"
    ],
    "author": "Anand Panchapakesan",
    "license": "MIT",
    "publishConfig": {
        "access": "public",
        "registry": "https://registry.npmjs.org/"
    },
    "repository": {
        "type": "git",
        "url": "https://github.com/smuit/smuit.git",
        "directory": "components/tabs"
    },
    "dependencies": {
        "bits-ui": "^2.18.1",
        "tailwind-merge": "^3.6.0",
        "tailwind-variants": "^3.2.2"
    },
    "peerDependencies": {
        "@smuit/theme": "workspace:*",
        "svelte": "^5.0.0",
        "tailwindcss": "^4.0.0"
    },
    "devDependencies": {
        "@smuit/theme": "workspace:*",
        "@sveltejs/package": "^2.3.0",
        "svelte": "^5.55.10"
    }
}
