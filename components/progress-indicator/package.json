{
    "name": "@wimwian-org/progress-indicator",
    "version": "0.2.0",
    "description": "Material Design 3–style linear progress indicator for Svelte 5 — determinate · indeterminate, retintable, sm/md/lg, on smuit design tokens.",
    "type": "module",
    "files": [
        "dist",
        "!dist/**/*.test.*",
        "!dist/**/*.spec.*"
    ],
    "svelte": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "svelte": "./dist/index.js",
            "default": "./dist/index.js"
        },
        "./package.json": "./package.json"
    },
    "scripts": {
        "package": "svelte-package -i src -o dist -t",
        "build": "svelte-package -i src -o dist -t",
        "prepublishOnly": "svelte-package -i src -o dist -t"
    },
    "sideEffects": [
        "**/*.css"
    ],
    "keywords": [
        "svelte",
        "svelte5",
        "progress",
        "progress-bar",
        "progress-indicator",
        "linear-progress",
        "material",
        "material-design"
    ],
    "author": "wimwian",
    "license": "MIT",
    "publishConfig": {
        "access": "public",
        "registry": "https://npm.pkg.github.com"
    },
    "repository": {
        "type": "git",
        "url": "https://github.com/wimwian-org/smuit.git",
        "directory": "components/progress-indicator"
    },
    "dependencies": {
        "tailwind-merge": "^3.6.0",
        "tailwind-variants": "^3.2.2"
    },
    "peerDependencies": {
        "@wimwian-org/theme": "workspace:*",
        "svelte": "^5.0.0",
        "tailwindcss": "^4.0.0"
    },
    "devDependencies": {
        "@wimwian-org/theme": "workspace:*",
        "@sveltejs/package": "^2.3.0",
        "svelte": "^5.55.10"
    }
}
