{
    "compilerOptions": {
        "target": "ES2022",
        "module": "ESNext",
        "moduleResolution": "bundler",
        "lib": ["ES2022", "DOM", "DOM.Iterable"],
        "types": ["node", "svelte", "vite/client"],
        "strict": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "isolatedModules": true,
        "verbatimModuleSyntax": true,
        "resolveJsonModule": true,
        "paths": {
            "$assets/*": ["./src/assets/*"],
            "$components/*": ["./src/components/*"],
            "$routes/*": ["./src/routes/*"],
            "$tests/*": ["./src/tests/*"]
        },
        "allowJs": true,
        "checkJs": true,
        "sourceMap": true,
        "noEmit": true
    },
    "include": ["src/**/*.ts", "src/**/*.js", "src/**/*.svelte", "*.config.ts", "*.config.js"]
}
