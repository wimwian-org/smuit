{
    "name": "smuit",
    "version": "0.1.0",
    "private": true,
    "description": "Material Design 3 components for Svelte",
    "packageManager": "pnpm@11.5.0",
    "scripts": {
        "check": "svelte-check --tsconfig ./tsconfig.json",
        "check:theme": "node scripts/check-theme.ts",
        "theme:regen": "node scripts/regen-theme.ts",
        "theme:watch": "node scripts/regen-theme.ts --watch",
        "format": "prettier --write .",
        "format:check": "prettier --check .",
        "lint": "eslint .",
        "lint:fix": "eslint . --fix",
        "commit": "cz",
        "changeset": "changeset",
        "version": "changeset version",
        "release": "changeset publish",
        "prepare": "lefthook install",
        "test": "vitest run",
        "test:browser": "vitest run --config vitest.browser.config.ts",
        "test:all": "pnpm test && pnpm test:browser",
        "coverage": "vitest run --coverage && vitest run --config vitest.browser.config.ts --coverage && node scripts/coverage-merge.mjs && node scripts/coverage-to-json.mjs && node scripts/git-status-to-json.mjs && node scripts/build-metadata.mjs",
        "coverage:all": "vitest run --coverage && vitest run --config vitest.browser.config.ts --coverage && node scripts/coverage-merge.mjs",
        "coverage:merge": "node scripts/coverage-merge.mjs",
        "meta": "node scripts/build-metadata.mjs",
        "status": "node scripts/git-status-to-json.mjs",
        "prune:branches": "node scripts/prune-branches.mjs",
        "package": "pnpm -r --filter './components/*' run package",
        "push:master": "node scripts/push-master.mjs"
    },
    "keywords": [],
    "author": "wimwian",
    "license": "MIT",
    "type": "module",
    "devDependencies": {
        "@changesets/changelog-github": "^0.5.0",
        "@changesets/cli": "^2.31.0",
        "@commitlint/cli": "^21.0.2",
        "@commitlint/config-conventional": "^21.0.2",
        "@eslint/js": "^10.0.1",
        "@sveltejs/adapter-static": "^3.0.0",
        "@sveltejs/kit": "^2.61.1",
        "@sveltejs/package": "^2.3.0",
        "@sveltejs/vite-plugin-svelte": "^7.1.2",
        "@tailwindcss/vite": "^4.3.0",
        "@types/node": "^25.9.1",
        "@vitest/browser": "4.1.7",
        "@vitest/browser-playwright": "4.1.7",
        "@vitest/coverage-istanbul": "4.1.7",
        "@vitest/coverage-v8": "4.1.7",
        "commitizen": "^4.3.1",
        "cz-conventional-changelog": "^3.3.0",
        "eslint": "^10.4.0",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-svelte": "^3.18.0",
        "glob": "^13.0.6",
        "globals": "^17.6.0",
        "lefthook": "^2.1.9",
        "playwright": "^1.60.0",
        "postcss": "^8.5.15",
        "prettier": "^3.8.3",
        "prettier-plugin-svelte": "^4.0.1",
        "svelte": "^5.55.10",
        "svelte-check": "^4.4.8",
        "tailwind-merge": "^3.6.0",
        "tailwind-variants": "^3.2.2",
        "tailwindcss": "^4.3.0",
        "typescript": "^6.0.3",
        "typescript-eslint": "^8.60.0",
        "vite": "^8.0.14",
        "vitest": "4.1.7",
        "vitest-browser-svelte": "^2.1.1"
    },
    "config": {
        "commitizen": {
            "path": "cz-conventional-changelog"
        }
    }
}
