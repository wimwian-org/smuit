{
    "name": "@wimwian-org/theme",
    "version": "0.1.3",
    "description": "Material Design 3 design tokens, oklch palettes, and Tailwind CSS v4 theme for smuit components",
    "type": "module",
    "exports": {
        ".": "./src/output.css",
        "./flat": "./src/output.css",
        "./css": "./src/theme.css",
        "./svelte": {
            "svelte": "./src/Theme.svelte",
            "default": "./src/Theme.svelte"
        },
        "./package.json": "./package.json"
    },
    "scripts": {
        "build:theme": "node src/build-theme.ts"
    },
    "files": [
        "src",
        "!src/backup",
        "LICENSE",
        "README.md",
        "CHANGELOG.md"
    ],
    "keywords": [
        "material-design",
        "material-design-3",
        "design-tokens",
        "tailwindcss",
        "oklch",
        "css",
        "svelte"
    ],
    "author": "wimwian",
    "license": "MIT",
    "publishConfig": {
        "access": "public",
        "registry": "https://npm.pkg.github.com"
    },
    "repository": {
        "type": "git",
        "url": "https://github.com/wimwian-org/smuit.git",
        "directory": "packages/theme"
    },
    "devDependencies": {
        "tailwindcss": "^4.3.0"
    },
    "peerDependencies": {
        "tailwindcss": "^4.0.0",
        "svelte": "^5.0.0"
    },
    "peerDependenciesMeta": {
        "tailwindcss": {
            "optional": true
        },
        "svelte": {
            "optional": true
        }
    }
}
